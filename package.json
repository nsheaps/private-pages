{
  "name": "private-pages",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Client-only GitHub Pages for private repos — authenticate via GitHub OAuth, clone with isomorphic-git into OPFS, render static sites in the browser",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:sw",
    "build:sw": "vite build --config vite.config.sw.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.sw.json",
    "validate": "npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "isomorphic-git": "^1.27.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.13.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.17.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
